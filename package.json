{
  "name": "rydo-monorepo",
  "version": "1.0.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "dependencies": {},
  "devDependencies": {
    "typescript": "~6.0.3"
  },
  "scripts": {
    "passenger": "npm run start -w @rydo/passenger",
    "passenger:web": "npm run web -w @rydo/passenger -- --port 8082 --host localhost",
    "driver": "npm run start -w @rydo/driver",
    "driver:web": "npm run web -w @rydo/driver -- --port 8083 --host localhost",
    "admin": "npm run start -w @rydo/admin",
    "admin:web": "npm run web -w @rydo/admin -- --port 8084 --host localhost",
    "typecheck": "npm run typecheck -w @rydo/passenger && npm run typecheck -w @rydo/driver && npm run typecheck -w @rydo/admin"
  },
  "private": true
}
