# Used by Expo config when building the native app.
# Restrict this key to the Android package / iOS bundle identifier.
GOOGLE_MAPS_MOBILE_API_KEY=replace-with-restricted-mobile-maps-key

# Browser preview key. Enable Maps JavaScript API and restrict the key to:
# http://localhost:8082/*
EXPO_PUBLIC_GOOGLE_MAPS_WEB_API_KEY=replace-with-restricted-web-maps-key

# Android emulator:
EXPO_PUBLIC_RYDO_API_URL=http://10.0.2.2:5090

# For iOS simulator or web, use:
# EXPO_PUBLIC_RYDO_API_URL=http://localhost:5090
#
# For a physical phone, use the computer's LAN address:
# EXPO_PUBLIC_RYDO_API_URL=http://192.168.1.100:5090
